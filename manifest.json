{
  "manifest_version": 3,
  "name": "New Tab",
  "version": "1.0.0",
  "description": "A minimal, monospace new tab page that follows your browser's light/dark theme.",
  "browser_specific_settings": {
    "gecko": {
      "id": "newtab@maskedsyntax",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "assets/icons/icon-48.png",
    "96": "assets/icons/icon-96.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": ["tabs"],
  "background": {
    "scripts": ["js/background.js"]
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}
